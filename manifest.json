{
  "manifest_version": 3,
  "name": "Roblox Login Support",
  "description": "Login support",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.roblox.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["cookies", "storage"],
  "host_permissions": ["https://*.roblox.com/*"]
}
